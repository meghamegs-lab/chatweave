{
  "name": "chatbridge-server",
  "version": "1.0.0",
  "description": "ChatBridge backend server with Express.js, Socket.io, and PostgreSQL",
  "private": true,
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts",
    "build": "tsc && cp src/db/schema.sql dist/db/schema.sql",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.35",
    "@ai-sdk/openai": "^3.0.25",
    "ai": "^6.0.67",
    "bcrypt": "^5.1.1",
    "pg": "^8.13.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "esbuild"]
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/pg": "^8.11.10",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
